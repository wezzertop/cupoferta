# IMGBB_API_KEY=your-imgbb-api-key-here

# ─── Telegram Bot (opcional) ─────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# TELEGRAM_CHANNEL_ID=your-channel-id-here
